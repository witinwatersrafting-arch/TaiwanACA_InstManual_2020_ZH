---
import "../styles/global.css";
import "../styles/print.css";

interface Props {
    title: string;
}

const { title } = Astro.props;

import Sidebar from "../components/navigation/Sidebar.astro";
import { ClientRouter } from 'astro:transitions';

const isAssessmentPage = Astro.url.pathname.includes("assessment-guide");
const isCurriculumPage = Astro.url.pathname.includes("river-kayaking-curriculum");
const isBoatSpecsPage = Astro.url.pathname.includes("boat-specs");
const isSkirtFitPage = Astro.url.pathname.includes("skirt-fit");

const rawBaseUrl = import.meta.env.BASE_URL;
// Ensure baseUrl ends with exactly one slash for safe joining
const baseUrl = rawBaseUrl.endsWith('/') ? rawBaseUrl : `${rawBaseUrl}/`;
---

<!DOCTYPE html>
<html lang="zh-TW">
    <head>
        <meta charset="UTF-8" />
        <meta
            name="description"
            content="ACA 獨木舟教練手冊 (2020) - 繁體中文版"
        />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
        <meta name="generator" content={Astro.generator} />
        <title>{title} | ACA 教練手冊</title>
        <ClientRouter />
    </head>
    <body
        class="bg-slate-50 text-slate-900 font-sans selection:bg-blue-100 selection:text-blue-900"
    >
        <div id="loading-bar"></div>
        <div class="flex flex-col lg:flex-row min-h-screen w-full">
            <!-- Mobile Header -->
            <div
                class="lg:hidden fixed top-0 left-0 right-0 z-50 bg-white border-b border-slate-200 px-6 py-4 flex items-center justify-between shadow-sm"
            >
                <div class="flex items-center gap-3 overflow-hidden mr-2">
                    <a
                        href={import.meta.env.BASE_URL}
                        class="flex items-center gap-2 shrink-0"
                    >
                        <div
                            class="w-7 h-7 bg-blue-600 rounded-lg flex items-center justify-center text-white font-black text-[10px]"
                        >
                            A
                        </div>
                        <h1
                            class="text-xs font-black tracking-tighter shrink-0"
                        >
                            ACA MANUAL
                        </h1>
                    </a>
                    <div class="h-4 w-[1px] bg-slate-200 shrink-0"></div>
                    <div
                        id="mobile-current-unit"
                        class="text-[11px] font-bold text-slate-500 truncate transition-all duration-500 min-w-0"
                    >
                        <!-- Dynamic Title -->
                    </div>
                </div>
                <button
                    id="mobile-menu-toggle"
                    class="p-2 -mr-2 text-slate-600 hover:text-blue-600 shrink-0 transition-colors"
                    aria-label="Toggle Menu"
                >
                    <svg
                        id="hamburger-icon"
                        class="w-6 h-6"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M4 6h16M4 12h16M4 18h16"></path>
                    </svg>
                    <svg
                        id="close-icon"
                        class="w-6 h-6 hidden"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M6 18L18 6M6 6l12 12"></path>
                    </svg>
                </button>
            </div>
            <!-- Spacer for fixed header -->
            <div class="lg:hidden h-16"></div>

            <!-- Sidebar Overlay (Mobile) -->
            <div
                id="sidebar-overlay"
                class="fixed inset-0 bg-slate-900/40 backdrop-blur-sm z-40 hidden opacity-0 transition-opacity duration-300 lg:hidden"
            >
            </div>

            <Sidebar baseUrl={baseUrl} currentPath={Astro.url.pathname} transition:persist />

            <!-- Main Content Area -->
            <main class="flex-1 bg-white relative min-w-0 w-full fade-in" id="main-content">
                <slot />
            </main>
        </div>

        <script>
            import { initLang, initModeSwitcher, initMobileMenu, initScrollSpy, initAnchorLinks } from "../scripts/ui";

            const init = () => {
                initLang();
                initModeSwitcher();
                initMobileMenu();
                initScrollSpy();
                initAnchorLinks();
            };

            const loadingBar = document.getElementById('loading-bar');
            
            document.addEventListener('astro:before-preparation', () => {
                if (loadingBar) {
                    loadingBar.style.width = '30%';
                    loadingBar.style.opacity = '1';
                }
            });

            document.addEventListener('astro:after-preparation', () => {
                if (loadingBar) {
                    loadingBar.style.width = '80%';
                }
            });

            document.addEventListener('astro:page-load', () => {
                if (loadingBar) {
                    loadingBar.style.width = '100%';
                    setTimeout(() => {
                        loadingBar.style.opacity = '0';
                        setTimeout(() => {
                            loadingBar.style.width = '0';
                        }, 300);
                    }, 200);
                }
                init();
            });
        </script>
    </body>
</html>
