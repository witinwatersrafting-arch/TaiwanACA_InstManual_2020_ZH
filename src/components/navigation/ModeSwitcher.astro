---
import { modes } from "../../config/navigation";

interface Props {
  baseUrl: string;
  currentPath: string;
}

const { baseUrl, currentPath } = Astro.props;
---

<div class="flex flex-col gap-2 mb-6" id="mode-switcher">
    <!-- 第一列：核心手冊內容 -->
    <div class="bg-slate-100 p-1 rounded-xl flex gap-1 border border-slate-200">
        {modes.slice(0, 3).map(mode => {
            const isActive = mode.id === 'manual' 
                ? (currentPath === baseUrl || currentPath === baseUrl.slice(0, -1))
                : (mode.id === 'assessment' ? currentPath.includes('assessment-guide') : currentPath.includes('river-kayaking-curriculum'));
            
            return (
                <a
                    href={`${baseUrl}${mode.path.replace(/^\//, '')}${mode.path.length > 1 ? '' : ''}?menu=open`}
                    class={`flex-1 py-2 px-1 rounded-lg text-[10px] font-bold text-center transition-all ${isActive ? 'bg-white shadow-sm text-blue-600 active-mode' : 'text-slate-500 hover:text-slate-800'}`}
                >
                    {mode.name}
                </a>
            );
        })}
    </div>
    <!-- 第二列：工具與規格 -->
    <div class="bg-slate-100 p-1 rounded-xl flex gap-1 border border-slate-200">
        {modes.slice(3).map(mode => {
            const isActive = mode.id === 'boat-specs' ? currentPath.includes('boat-specs') : currentPath.includes('skirt-fit');
            
            return (
                <a
                    href={`${baseUrl}${mode.path.replace(/^\//, '')}?menu=open`}
                    class={`flex-1 py-2 px-1 rounded-lg text-[10px] font-bold text-center transition-all ${isActive ? 'bg-white shadow-sm text-blue-600 active-mode' : 'text-slate-500 hover:text-slate-800'}`}
                >
                    {mode.name}
                </a>
            );
        })}
    </div>
</div>
