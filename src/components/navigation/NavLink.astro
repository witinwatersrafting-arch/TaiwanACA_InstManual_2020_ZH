---
interface Props {
  href: string;
  zh: string;
  en: string;
  id: string;
}

const { href, zh, en, id } = Astro.props;
---

<a
  href={href}
  data-nav-id={id}
  class="nav-link flex flex-col px-4 py-3 rounded-xl hover:bg-blue-50 transition-all group"
>
  <span class="zh text-sm font-bold text-slate-700 group-hover:text-blue-600 leading-snug transition-colors">{zh}</span>
  <span class="en text-sm font-bold text-slate-700 group-hover:text-blue-600 leading-snug mt-0.5 transition-colors">{en}</span>
</a>
