---
import { getEntry, render } from 'astro:content';
import Icon from './LucideIcon.astro';
import Callout from './Callout.astro';
import ExerciseIllustration from './ExerciseIllustration.astro';
import SectionHeader from './SectionHeader.astro';

interface Props {
  slug: string;
}

const { slug } = Astro.props;
const entry = await getEntry('manual', slug);

if (!entry) {
  throw new Error(`Unit with slug "${slug}" not found`);
}

const { Content } = await render(entry);
---

<div class="manual-unit max-w-4xl mx-auto">
  <!-- Automated Unit Header (Componentized) -->
  {entry.data.unit_number > 0 && (
    <SectionHeader 
      id={slug}
      titleZh={entry.data.title}
      titleEn={entry.data.en_title}
      descZh={entry.data.description}
      descEn={entry.data.en_description}
    />
  )}

  <article class="prose prose-slate max-w-none prose-headings:font-black prose-p:leading-relaxed prose-li:my-1">
    <Content components={{ Icon, Callout, ExerciseIllustration }} />
  </article>
</div>
