---
import SectionHeader from "./SectionHeader.astro";

interface Props {
  title_zh: string;
  title_en: string;
  description_zh: string;
  description_en: string;
  evalMethod_zh?: string;
  evalMethod_en?: string;
  meetsStandard_zh?: string;
  meetsStandard_en?: string;
  belowStandard_zh?: string;
  belowStandard_en?: string;
  rows: {
    name_zh: string;
    name_en: string;
    levels: { zh: string; en: string }[];
  }[];
}

const {
  title_zh,
  title_en,
  description_zh,
  description_en,
  evalMethod_zh,
  evalMethod_en,
  meetsStandard_zh,
  meetsStandard_en,
  belowStandard_zh,
  belowStandard_en,
  rows,
} = Astro.props;
---

<section class="mb-24 scroll-mt-24" id={title_en.toLowerCase().replace(/\s+/g, '-')}>
  <SectionHeader 
    titleZh={title_zh}
    titleEn={title_en}
    descZh={description_zh}
    descEn={description_en}
  />

  <!-- Evaluation Criteria Grid -->
  <div class="mb-12 grid grid-cols-1 md:grid-cols-3 gap-8">
    {evalMethod_zh && (
      <div class="p-6 bg-slate-50 rounded-2xl border border-slate-100">
        <h4 class="text-xs font-black uppercase tracking-widest text-[#4796cc] mb-3">Evaluation Method</h4>
        <p class="zh text-slate-700 text-sm leading-relaxed mb-2">{evalMethod_zh}</p>
        <p class="en text-slate-600 text-[12px] leading-tight">{evalMethod_en}</p>
      </div>
    )}
    {meetsStandard_zh && (
      <div class="p-6 bg-emerald-50/50 rounded-2xl border border-emerald-100">
        <h4 class="text-xs font-black uppercase tracking-widest text-emerald-600 mb-3">Meets Standard</h4>
        <p class="zh text-slate-700 text-sm leading-relaxed mb-2">{meetsStandard_zh}</p>
        <p class="en text-slate-600 text-[12px] leading-tight">{meetsStandard_en}</p>
      </div>
    )}
    {belowStandard_zh && (
      <div class="p-6 bg-rose-50/50 rounded-2xl border border-rose-100">
        <h4 class="text-xs font-black uppercase tracking-widest text-rose-600 mb-3">Below Standard</h4>
        <p class="zh text-slate-700 text-sm leading-relaxed mb-2">{belowStandard_zh}</p>
        <p class="en text-slate-600 text-[12px] leading-tight">{belowStandard_en}</p>
      </div>
    )}
  </div>

  <!-- Rubric Table / Grid -->
  <div class="rounded-3xl border border-slate-200 overflow-hidden shadow-sm bg-white">
    <!-- Desktop Header: 5 Equal Columns (Brand Blue) -->
    <div class="hidden lg:grid print:grid grid-cols-5 bg-[#4796cc] text-white font-black text-[10px] uppercase tracking-[0.2em] py-6 px-4">
      <div class="px-6 border-r border-white/10 flex items-center">技能指標</div>
      {[2, 3, 4, 5].map(level => (
        <div class="px-4 border-r border-white/10 last:border-r-0 text-center flex items-center justify-center">Level {level}</div>
      ))}
    </div>

    <!-- Rows -->
    <div class="divide-y divide-slate-100">
      {rows.map((row) => (
        <div class="group">
          <!-- Desktop Row: 5 Equal Columns -->
          <div class="hidden lg:grid print:grid grid-cols-5 hover:bg-blue-50/30 transition-colors">
            <div class="p-6 border-r border-slate-100 font-bold text-slate-800 flex flex-col justify-center">
              <span class="zh block text-base leading-tight">{row.name_zh}</span>
              <span class="en block text-[10px] text-[#4796cc] font-bold uppercase tracking-wider mt-1">{row.name_en}</span>
            </div>
            {row.levels.map((level, i) => (
              <div class="p-6 border-r border-slate-100 last:border-r-0">
                <div class="zh text-[13px] text-slate-700 leading-relaxed mb-2 font-medium whitespace-pre-wrap">{level.zh}</div>
                <div class="en text-[11px] text-slate-600 leading-snug whitespace-pre-wrap">{level.en}</div>
              </div>
            ))}
          </div>

          <!-- Mobile View: Simple Cards -->
          <div class="lg:hidden print:hidden p-8 space-y-6">
            <h4 class="text-xl font-black text-slate-900 border-b-2 border-slate-100 pb-3 mb-6">
              <span class="zh block">{row.name_zh}</span>
              <span class="en block text-[11px] text-[#4796cc] uppercase tracking-widest mt-1">{row.name_en}</span>
            </h4>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              {row.levels.map((level, i) => (
                <div class="bg-slate-50/50 rounded-2xl p-6 border border-slate-100">
                  <div class="flex items-center gap-2 mb-4">
                    <span class="text-[9px] font-black uppercase tracking-widest bg-slate-200 text-slate-600 px-2 py-0.5 rounded-full">Level {i+2}</span>
                  </div>
                  <p class="zh text-slate-700 text-sm font-medium leading-relaxed mb-2">{level.zh}</p>
                  <p class="en text-slate-600 text-xs leading-snug">{level.en}</p>
                </div>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .zh { word-break: break-all; }
  .en { word-break: break-word; }

  @media print {
    /* 縮小量表字體以適應 A4 寬度 */
    .zh {
      font-size: 11px !important;
    }
    .en {
      font-size: 9px !important;
    }
    .font-black.text-\[10px\] {
      font-size: 9px !important;
    }

    /* 強化表格邊框 */
    .border-slate-100, .border-slate-200 {
      border-color: #cbd5e1 !important;
    }

    /* 避免表格行在分頁時被切斷 */
    .group {
      break-inside: avoid !important;
      page-break-inside: avoid !important;
    }

    /* 強制顯示背景顏色（特別是表頭） */
    .bg-\[\#4796cc\] {
      background-color: #4796cc !important;
      -webkit-print-color-adjust: exact !important;
      print-color-adjust: exact !important;
    }
    
    .text-white {
      color: white !important;
    }

    /* 移除陰影 */
    .shadow-sm {
      box-shadow: none !important;
    }
  }
</style>
