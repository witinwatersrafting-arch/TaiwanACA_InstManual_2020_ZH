---
interface Props {
  titleZh: string;
  titleEn: string;
  descZh?: string;
  descEn?: string;
  id?: string;
}

const { titleZh, titleEn, descZh, descEn, id } = Astro.props;
---

<div class="section-header border-l-8 border-[#4796cc] pl-8 mb-16 scroll-mt-24" id={id}>
  <h2 class="text-3xl md:text-5xl font-black serif mb-6 text-slate-900 flex flex-col gap-2">
    <span class="zh">{titleZh}</span>
    <span class="en text-sm md:text-base text-slate-500 font-normal tracking-wider uppercase">{titleEn}</span>
  </h2>
  {(descZh || descEn) && (
    <div class="max-w-4xl space-y-4">
      {descZh && <p class="zh text-slate-600 text-lg leading-relaxed m-0">{descZh}</p>}
      {descEn && <p class="en text-slate-500 text-base leading-relaxed m-0 italic">{descEn}</p>}
    </div>
  )}
</div>

<style is:global>
  @media print {
    .section-header {
      break-after: avoid !important;
      page-break-after: avoid !important;
      margin-bottom: 2rem !important;
    }
    
    .section-header h2 {
      font-size: 2rem !important;
      margin-bottom: 1rem !important;
    }

    .section-header p {
      font-size: 1rem !important;
      line-height: 1.5 !important;
    }
  }
</style>
