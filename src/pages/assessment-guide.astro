<Layout title="ACA 溪流獨木舟指導員技能評估量表">
  <div class="bg-slate-50 min-h-screen">
    <div class="max-w-6xl mx-auto py-12 px-6 md:py-20 lg:px-8">
      
      <!-- Hero Section -->
      <header class="mb-16 text-center">
        <div class="inline-block bg-[#4796cc] text-white px-4 py-1.5 rounded-full text-xs font-bold uppercase tracking-widest mb-6">
          Whitewater Instructor Assessment
        </div>
        <h1 class="text-4xl md:text-6xl font-black serif text-slate-900 mb-6 leading-tight">
          ACA 溪流獨木舟指導員<br/><span class="text-[#4796cc]">技能評估指標量表</span>
        </h1>
        <div class="max-w-3xl mx-auto space-y-6 text-left bg-white p-8 rounded-2xl shadow-sm border border-slate-200">
          <h2 class="text-xl font-bold text-slate-800 flex items-center gap-2">
             ACA 指導員技能評估程序與指標 (Rubric)
          </h2>
          <p class="text-slate-600 text-sm md:text-base leading-relaxed">
            本量表是專門為 <strong>ACA 溪流獨木舟指導員 (Whitewater Kayak Instructor)</strong> 認證設計的技術標準。評估員將根據此量表，針對各級別 (Level 2-5) 候選人的技術知識、划行槳法、流水操縱以及風險管理能力進行全方位的專業評核。
          </p>
          <ul class="space-y-3 text-slate-600 text-sm md:text-base leading-relaxed list-disc pl-5">
            <li><strong>認證資格</strong>：候選人必須由取得認證的 ACA 教練導師 (IT) 或資深導師 (ITE) 進行評估。</li>
            <li><strong>場地標準</strong>：評估場地必須與申請之等級相符（如 L4 應於 II/III 級水域進行）。</li>
            <li><strong>標竿指標</strong>：候選人需在各項技能中展現出該等級所要求的「角色楷模 (Role Model)」示範水準。</li>
          </ul>
          <div class="pt-4 border-t border-slate-100 italic text-sm text-slate-400">
            教練認證考試 (ICE) 亦適用此量表，教練候選人應具備示範與教學之深度能力。
          </div>
        </div>
      </header>

      <!-- Rubric Sections -->
      <AssessmentRubric 
        title="技術知識" 
        description="涵蓋槳類運動安全、裝備、划船理論、河流判讀、跑河策略及救援之通識。須具備以淺顯易懂的語言解釋專業概念之能力。"
        rows={technicalKnowledgeRows}
      />

      <AssessmentRubric 
        title="靜水槳法" 
        description="靜水技能是划船技術的基石。透過靜水練習，能專注於槳法效率與技術修正，而不受水流干擾。"
        rows={flatWaterRows}
      />

      <AssessmentRubric 
        title="動態水域技術" 
        description="候選人應能在其申請評定之水域場地中，自信且有效地操縱船隻，展現動作的優雅與受控感。"
        rows={movingWaterRows}
      />

      <AssessmentRubric 
        title="風險管理" 
        description="候選人能正確評估並管理與其申請評等相關之划船風險。重視救援之速度、簡易性與安全性（簡單、安全、迅速為最高原則）。"
        rows={riskManagementRows}
      />

