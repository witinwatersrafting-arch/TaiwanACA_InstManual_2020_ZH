<script>
  const init = () => {
    const inputElbow = document.getElementById('input-elbow') as HTMLInputElement;
    const inputPower = document.getElementById('input-power') as HTMLSelectElement;
    const inputWeight = document.getElementById('input-weight') as HTMLInputElement;
    const inputDisciplines = document.querySelectorAll('input[name="discipline"]');
    
    const resultTotal = document.getElementById('result-total');
    const resultGrip = document.getElementById('result-grip');
    const resultBlade = document.getElementById('result-blade');
    const resultFeather = document.getElementById('result-feather');

    const calculate = () => {
      const elbow = parseFloat(inputElbow.value) || 0;
      const weight = parseFloat(inputWeight.value) || 0;
      const powerValue = inputPower.value;
      const power = (powerValue === 'NOT_EVEN_ONE') ? -1 : parseInt(powerValue);

      // 1. Grip Width (45 degree biomechanical constant)
      const grip = Math.round(elbow * 0.658 * 10) / 10;
      
      // 2. Total Length & Power Offset Logic (Refined by CSV Analysis)
      let powerOffset = 0;
      if (power === 20) {
        powerOffset = 2.0;
      } else if (power === 10) {
        // Special Case: Power 10 bonus disappears for very heavy users (100kg+)
        powerOffset = weight >= 100 ? 0 : 1.0;
      }

      const total = Math.round(((elbow * 0.83) + 116.85 + powerOffset) * 10) / 10;

      // 3. Blade Surface Matrix Logic (Derived from analyze_blade.py)
      let blade = "Medium-Large";
      if (power >= 10) {
          if (weight < 55) blade = "Medium-Large";
          else if (weight < 95) blade = "Large-XLarge";
          else blade = "XLarge";
      } else if (power >= 5) {
          if (weight < 55) blade = "Small-Medium";
          else if (weight < 75) blade = "Large";
          else if (weight < 95) blade = "Large-XLarge";
          else blade = "XLarge";
      } else {
          if (weight < 55) blade = "Small-Medium";
          else if (weight < 75) blade = "Medium-Large";
          else if (weight < 95) blade = "Large";
          else blade = "XLarge";
      }

      if (resultGrip) resultGrip.textContent = grip.toFixed(1);
      if (resultTotal) resultTotal.textContent = total.toFixed(1);
      if (resultBlade) resultBlade.textContent = blade;
    };

    [inputElbow, inputPower, inputWeight].forEach(el => {
      el?.addEventListener('input', calculate);
    });

    calculate(); // Initial run
  };

  init();
  document.addEventListener('astro:page-load', init);
</script>
