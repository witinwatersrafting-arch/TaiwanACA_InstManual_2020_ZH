---
import Layout from "../layouts/Layout.astro";
import ManualUnit from "../components/ManualUnit.astro";
import Copyright from "../components/Copyright.astro";
import { getCollection } from "astro:content";

const manualUnits = await getCollection("manual");
// Sort units by unit_number
manualUnits.sort((a, b) => {
    const orderA = a.data.unit_number ?? 999;
    const orderB = b.data.unit_number ?? 999;
    return orderA - orderB;
});
---

<Layout title="手冊全集">
    <div class="max-w-4xl mx-auto py-20 px-5 md:px-8">
        <!-- New Link to Assessment Guide -->
        <div class="mb-20 p-8 rounded-2xl bg-white border border-slate-200 shadow-sm flex flex-col md:flex-row items-center justify-between gap-6">
            <div class="text-center md:text-left">
                <h3 class="text-xl font-bold text-slate-800 mb-1">ACA 溪流獨木舟指導員技能量表</h3>
                <p class="text-sm text-slate-500">查看完整 L2-L5 指導員級別技能指標與評分量表</p>
            </div>
            <a href={`${import.meta.env.BASE_URL}/assessment-guide`} class="bg-[#4796cc] hover:bg-[#357abd] text-white px-6 py-3 rounded-full font-bold transition-all shadow-md hover:shadow-lg">
                前往評估指南 →
            </a>
        </div>

        <div class="space-y-32">
            {
                manualUnits.map((unit) => (
                    <section id={unit.id} class="scroll-mt-24">
                        <ManualUnit slug={unit.id} />
                    </section>
                ))
            }
        </div>

        <Copyright />
    </div>
</Layout>
