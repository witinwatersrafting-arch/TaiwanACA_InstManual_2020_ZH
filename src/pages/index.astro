---
import Layout from "../layouts/Layout.astro";
import ManualUnit from "../components/ManualUnit.astro";
import Copyright from "../components/Copyright.astro";
import { getCollection } from "astro:content";

const manualUnits = await getCollection("manual");
// Sort units by unit_number
manualUnits.sort((a, b) => {
    const orderA = a.data.unit_number ?? 999;
    const orderB = b.data.unit_number ?? 999;
    return orderA - orderB;
});

// Filter out 00-preamble as it is now part of the hardcoded Hero/Acknowledgments
const filteredUnits = manualUnits.filter(unit => unit.id !== '00-preamble');

const baseUrl = import.meta.env.BASE_URL;
---

<Layout title="ACA 溪流獨木舟指導員手冊">
    <div class="max-w-5xl mx-auto py-16 px-6 md:py-28">
        
        <!-- Hero Section (Bilingual Redesign) -->
        <header class="text-center mb-28">
            <div class="inline-block bg-[#4796cc] text-white px-8 py-2.5 rounded-full text-[10px] font-black uppercase tracking-[0.2em] mb-12 shadow-md">
                <span class="zh">指導員手冊</span>
                <span class="en">Instructor's Manual</span>
            </div>
            
            <h1 class="text-4xl md:text-7xl font-black serif leading-[1.1] mb-10 tracking-tight">
                <span class="zh">
                    <span class="text-slate-900 block mb-4">美國獨木舟協會</span>
                    <span class="text-[#4796cc] block">教練手冊</span>
                </span>
                <span class="en">
                    <span class="text-slate-900 block mb-4 text-3xl md:text-5xl uppercase tracking-tighter">American Canoe Association</span>
                    <span class="text-[#4796cc] block text-4xl md:text-6xl">Instructor's Manual</span>
                </span>
            </h1>
            
            <div class="max-w-2xl mx-auto text-slate-500 text-lg md:text-xl leading-relaxed mb-12 font-medium">
                <p class="zh">本手冊旨在支持所有 ACA 划行領域的教練培訓課程，凝聚了划行專家、教練與培訓師的集體智慧。</p>
                <p class="en italic">This manual is intended to support all ACA paddling disciplines' instructor training courses, bringing together the collective wisdom of paddling experts, instructors, and trainers.</p>
            </div>
            
            <div class="flex justify-center">
                <div class="w-16 h-1.5 bg-[#4796cc] rounded-full"></div>
            </div>
        </header>

        <!-- Acknowledgments Section (Bilingual Redesign) -->
        <section class="mb-40">
            <div class="border-b-2 border-slate-100 pb-5 mb-10">
                <h2 class="text-4xl font-black text-slate-900 tracking-tight">
                    <span class="zh">致謝</span>
                    <span class="en uppercase tracking-widest text-3xl">Acknowledgments</span>
                </h2>
            </div>
            
            <div class="text-slate-600 text-lg leading-relaxed mb-16">
                <p class="zh">本手冊的編寫與製作凝聚了美國獨木舟協會受薪職員與志工的共同努力。若非多位專業人士的慷慨貢獻，本手冊將無法問世。</p>
                <p class="en italic text-base">The compilation and production of this manual represents the collective effort of ACA staff and volunteers. Without the generous contributions of many professionals, this manual would not be possible.</p>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-16">
                <div class="space-y-6">
                    <h3 class="text-lg font-black text-slate-900">
                        <span class="zh">專業指導與貢獻：</span>
                        <span class="en block text-sm uppercase tracking-wider text-[#4796cc] mb-1">Professional Guidance & Contribution:</span>
                    </h3>
                    <p class="text-slate-500 italic leading-[1.8] text-base font-medium">
                        Virgil Chambers, Leeann Rhoades, Leslie White, Charlie Wilson, Jeremy Oyen, Gregory Wolfe, Kim Whitley, Julian Basham, Gordon Black, Wyatt G. Boughter, Paul Sanford, Janet Zeller.
                    </p>
                </div>
                <div class="space-y-6">
                    <h3 class="text-lg font-black text-slate-900">
                        <span class="zh">手冊修訂團隊 (02/2013)：</span>
                        <span class="en block text-sm uppercase tracking-wider text-[#4796cc] mb-1">Manual Revision Team (02/2013):</span>
                    </h3>
                    <p class="text-slate-500 italic leading-[1.8] text-base font-medium">
                        Trey Knight (教育外聯 / Education Outreach), Kelsey Bracewell (安全教育 / Safety Education), Chris Stec (首席運營官 / COO).
                    </p>
                </div>
            </div>
        </section>

        <!-- Manual Units Sections -->
        <div class="space-y-40">
            {
                filteredUnits.map((unit) => (
                    <section id={unit.id} class="scroll-mt-32">
                        <ManualUnit slug={unit.id} />
                    </section>
                ))
            }
        </div>

        <div class="mt-40">
            <Copyright />
        </div>
    </div>
</Layout>
