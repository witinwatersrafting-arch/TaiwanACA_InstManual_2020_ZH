---
import Copyright from "../components/Copyright.astro";
import StandardPage from "../components/StandardPage.astro";
import { getEntry, render } from "astro:content";
import CurriculumSection from "../components/curriculum/CurriculumSection.astro";
import TimelineStep from "../components/curriculum/TimelineStep.astro";
import LessonNote from "../components/curriculum/LessonNote.astro";
import SectionHeader from "../components/SectionHeader.astro";

const entry = await getEntry("manual", "river-kayaking-101");
if (!entry) {
  return Astro.redirect("/404");
}

const { Content } = await render(entry);
---

<StandardPage 
  title="激流獨木舟教學進度表"
  badgeZh="激流獨木舟課程"
  badgeEn="Whitewater Kayaking Curriculum"
  heroTitleMainZh="激流獨木舟"
  heroTitleSubZh="教學進度表"
  heroTitleMainEn="Whitewater Kayaking"
  heroTitleSubEn="Instruction Field Guide"
  descriptionZh="專為教練現場參考設計的時序排版。結合 ACA 技術大綱與「入門/初階」實務教學流程，確保教學邏輯嚴謹且符合現場安全規範。"
  descriptionEn="A time-based instruction guide designed for field reference. Integrates ACA technical standards with Introductory and Elementary practical teaching flows."
>

    <!-- Timeline Container -->
    <div class="curriculum-timeline max-w-4xl mx-auto">
      <Content components={{ CurriculumSection, TimelineStep, LessonNote, SectionHeader }} />
    </div>

  </StandardPage>

<style is:global>
  /* Remove default prose styling that interferes with timeline */
  .curriculum-timeline h1 { @apply hidden; }
  /* .curriculum-timeline p { @apply m-0; } */
  .curriculum-timeline ul { @apply list-none pl-0 space-y-4; }
  .curriculum-timeline li { 
    @apply flex flex-col md:flex-row md:items-start gap-1 md:gap-6 text-slate-600 font-medium leading-relaxed; 
  }
  .curriculum-timeline li strong {
    @apply text-slate-900 shrink-0 md:w-32 lg:w-40 pb-1 md:pb-0 flex items-center justify-between md:justify-start;
  }
  /* 僅在桌面版自動補齊冒號 */
  @media (min-width: 768px) {
    .curriculum-timeline li strong::after {
      content: "：";
      @apply ml-auto md:ml-0;
    }
  }
  
  .serif { font-family: "Noto Serif TC", serif; }
  .zh { word-break: break-all; }
  .en { word-break: break-word; }

  @media print {
    /* 優化列印基礎設定 */
    .max-w-5xl, .max-w-4xl {
      max-width: 100% !important;
      width: 100% !important;
      padding: 0 !important;
      margin: 0 !important;
    }
    
    header, .page-hero {
      /* PageHero handles its own internal global print styles */
    }
    
    footer {
      display: none !important;
    }
    
    /* 避免技術卡片與區塊被切斷 */
    .rounded-2xl, .curriculum-timeline > div {
      break-inside: avoid;
      page-break-inside: avoid;
      margin-bottom: 1.5rem !important;
    }

    /* 確保大標題與其下方的內容保持在一起，避免標題孤立 */
    .border-l-8 {
      break-after: avoid;
      page-break-after: avoid;
      margin-bottom: 1.5rem !important;
    }

    h2, h3 {
      break-after: avoid !important;
      page-break-after: avoid !important;
    }
    
    /* 強化時間軸視覺 - 在列印時線條要更明顯 */
    .curriculum-timeline .relative.pl-8 {
      padding-left: 2rem !important;
    }
    
    .curriculum-timeline .absolute.left-0.w-px {
      width: 2px !important;
      background-color: #e2e8f0 !important;
    }
    
    .curriculum-timeline .absolute.left-0.rounded-full {
      border: 2px solid #4796cc !important;
      background-color: #4796cc !important;
    }

    /* 調整內容網格 */
    .grid-cols-1 {
      grid-template-columns: repeat(2, minmax(0, 1fr)) !important;
      gap: 1.5rem !important;
    }
    
    .lg\:grid-cols-4 {
      grid-template-columns: repeat(2, minmax(0, 1fr)) !important;
    }

    /* 隱藏影片區塊與互動元素 */
    .aspect-video, button, .shadow-lg, iframe {
      display: none !important;
    }
    
    /* 調整顏色以利列印 */
    .bg-slate-50, .bg-blue-50, .bg-amber-50 {
      background-color: #f8fafc !important; /* 統一使用極淺灰色 */
      border: 1px solid #e2e8f0 !important;
    }

    /* 強制顏色顯示 */
    * {
      -webkit-print-color-adjust: exact !important;
      print-color-adjust: exact !important;
      color-adjust: exact !important;
    }

    /* 移除裝飾用線條或圓角陰影 */
    .shadow-md, .shadow-xl, .shadow-2xl {
      box-shadow: none !important;
    }
  }
</style>
